# Files NOT uploaded to App Engine by `gcloud app deploy`.
# Same syntax as .gitignore. The app only needs main.py, app.yaml, requirements.txt.

.gcloudignore
.git
.gitignore

# Virtualenvs — these are why the upload ballooned to ~1400 files / 89MB.
env/
.venv/
venv/

# Python caches / local pins
__pycache__/
*.pyc
.python-version
/setup.cfg

# Editor / OS / agent cruft and the assignment brief — not part of the app
.DS_Store
.claude/
*.pdf
